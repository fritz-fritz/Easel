From 3f847167cc5cd7ec1ecdb14d6f9b7c37b30aa661 Mon Sep 17 00:00:00 2001
From: Cursor Agent <cursoragent@cursor.com>
Date: Sun, 19 Jul 2026 08:51:47 +0000
Subject: [PATCH] fix(ci): fall back to libheif-vX.Y.Z-rN when tag is
 immutable-burned
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

GitHub immutable releases permanently reserve a tag name. On publish
failure, try rebuild tags (-r2, -r3, …) so corrected assets can ship.

Co-authored-by: FRITZ|FRITZ <fritz-fritz@users.noreply.github.com>
---
 .github/workflows/build-libheif-windows.yml | 39 +++++++++++++++++----
 1 file changed, 32 insertions(+), 7 deletions(-)

diff --git a/.github/workflows/build-libheif-windows.yml b/.github/workflows/build-libheif-windows.yml
index 6b3e67b..aa1559c 100644
--- a/.github/workflows/build-libheif-windows.yml
+++ b/.github/workflows/build-libheif-windows.yml
@@ -142,7 +142,8 @@ jobs:
           $sha = "${{ steps.pkg.outputs.sha256 }}"
           if ($env:GITHUB_REF -like "refs/tags/libheif-v*") {
             $tag = $env:GITHUB_REF_NAME
-            if ($tag -ne "libheif-v$ver") {
+            # Allow rebuild tags: libheif-vX.Y.Z or libheif-vX.Y.Z-rN
+            if ($tag -notmatch "^libheif-v$([regex]::Escape($ver))(-r\d+)?$") {
               throw "git tag $tag does not match packaged libheif-v$ver"
             }
           } else {
@@ -166,11 +167,35 @@ jobs:
             "Extract and set ``VCPKG_ROOT`` to the extract root before building Easel.",
             "The zip root must contain ``.vcpkg-root`` and ``installed/``."
           ) -join "`n"
-          $existing = gh release view $tag 2>$null
-          if ($LASTEXITCODE -ne 0) {
-            gh release create $tag $path $sum --title $tag --notes $notes
-          } else {
-            gh release upload $tag $path $sum --clobber
-            gh release edit $tag --notes $notes
+
+          function Publish-Release([string]$ReleaseTag) {
+            $view = gh release view $ReleaseTag 2>$null
+            if ($LASTEXITCODE -ne 0) {
+              gh release create $ReleaseTag $path $sum --title $ReleaseTag --notes $notes
+              return $LASTEXITCODE
+            }
+            gh release upload $ReleaseTag $path $sum --clobber
+            if ($LASTEXITCODE -ne 0) { return $LASTEXITCODE }
+            gh release edit $ReleaseTag --notes $notes
+            return $LASTEXITCODE
+          }
+
+          $code = Publish-Release $tag
+          if ($code -ne 0) {
+            # GitHub immutable releases permanently burn a tag even after deletion.
+            # Fall back to libheif-vX.Y.Z-rN rebuild tags.
+            $base = "libheif-v$ver"
+            for ($n = 2; $n -le 20; $n++) {
+              $candidate = "$base-r$n"
+              Write-Warning "Publish to $tag failed; trying rebuild tag $candidate"
+              $code = Publish-Release $candidate
+              if ($code -eq 0) {
+                $tag = $candidate
+                break
+              }
+            }
+            if ($code -ne 0) {
+              throw "failed to publish release for libheif $ver (immutable tag conflict?)"
+            }
           }
           Write-Host "Published $tag / $asset (sha256=$sha)"
-- 
